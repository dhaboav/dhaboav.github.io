{
    "name": "portofolio-website",
    "version": "2.1.0",
    "description": "portofolio website for personal usage",
    "types": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "deploy": "gh-pages -d dist",
        "format": "prettier --write \"src/**/*.{ts,tsx}\"",
        "format:md": "prettier --write \"public/blog/**/*.md\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
    },
    "keywords": [
        "portfolio",
        "website",
        "HTML",
        "css",
        "javascript"
    ],
    "author": "dhaboav",
    "license": "MIT",
    "devDependencies": {
        "@tailwindcss/typography": "^0.5.20",
        "@types/node": "^25.9.3",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/react-router-dom": "^5.3.3",
        "@types/react-router-hash-link": "^2.4.9",
        "@vitejs/plugin-react": "^6.0.2",
        "gh-pages": "^6.3.0",
        "prettier": "^3.7.3",
        "prettier-plugin-tailwindcss": "^0.7.1",
        "tailwindcss": "^4.3.1",
        "typescript": "^6.0.3",
        "vite": "^8.0.16"
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.3.1",
        "class-variance-authority": "^0.7.1",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-markdown": "^10.1.0",
        "react-router-dom": "^7.17.0",
        "react-router-hash-link": "^2.4.3",
        "tailwind-merge": "^3.6.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dhaboav/dhaboav.github.io.git"
    },
    "type": "commonjs",
    "bugs": {
        "url": "https://github.com/dhaboav/dhaboav.github.io/issues"
    },
    "homepage": "https://github.com/dhaboav/dhaboav.github.io#readme"
}
